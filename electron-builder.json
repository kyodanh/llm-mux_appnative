{
  "appId": "com.llmmux.manager",
  "productName": "LLM-Mux Manager",
  "directories": { "output": "dist" },
  "files": [
    "main.js",
    "preload.js",
    "renderer/**",
    "src/**",
    "node_modules/**",
    "package.json"
  ],
  "mac": {
    "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
    "category": "public.app-category.developer-tools",
    "identity": null
  },
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }]
  },
  "dmg": {
    "title": "LLM-Mux Manager"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
